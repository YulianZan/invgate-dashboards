# Renombrar este archivo a .env y completar los valores

INVGATE_URL=https://bdocl.sd.cloud.invgate.net
INVGATE_USER=tu_usuario
INVGATE_PASS=tu_password

# Puerto donde quedara disponible el dashboard
DASHBOARD_PORT=8080

# Hilos paralelos para descargar tickets
MAX_WORKERS=10

# Cron schedule (default: cada hora en punto)
# Ejemplos:
#   cada hora       -> 0 * * * *
#   cada 30 min     -> */30 * * * *
#   cada dia 6am    -> 0 6 * * *
CRON_SCHEDULE=0 * * * *
