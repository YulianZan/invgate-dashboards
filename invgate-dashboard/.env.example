# Copiar este archivo como .env y completar los valores reales.
#
#   cp .env.example .env
#
# No subir .env al repositorio: contiene credenciales.

# URL base de InvGate Service Management.
# Usar la URL del portal, sin /api ni /api/v1 al final.
INVGATE_URL=https://tuempresa.sd.cloud.invgate.net

# Credenciales de InvGate.
INVGATE_USER=tu_usuario
INVGATE_PASS=tu_password

# Puerto local donde quedara disponible el dashboard.
# Ejemplo: http://localhost:8080
DASHBOARD_PORT=8080

# ID del campo personalizado de InvGate que contiene el area.
# En esta instancia, custom_fields["72"] trae valores como "Auditoria UNE".
AREA_CUSTOM_FIELD_ID=72

# Hilos paralelos para descargar tickets.
# Mantener bajo para evitar HTTP 429 Too many requests.
MAX_WORKERS=3

# Reintentos por request cuando la API responde 429/5xx o hay errores transitorios.
HTTP_MAX_RETRIES=6

# Pausa minima global entre llamadas HTTP.
REQUEST_DELAY_SECONDS=0.25

# Espera base cuando la API responde 429 y no envia header Retry-After.
RATE_LIMIT_BACKOFF_SECONDS=30

# Cron schedule para la extraccion incremental.
# Default: cada hora en punto.
#
# Ejemplos:
#   Cada hora    -> "0 * * * *"
#   Cada 30 min  -> "*/30 * * * *"
#   Cada dia 6am -> "0 6 * * *"
CRON_SCHEDULE="0 * * * *"
